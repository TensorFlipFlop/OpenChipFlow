#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GO_BIN="$HOME/.local/go/bin/go"
if [ ! -x "$GO_BIN" ]; then
  echo "[ERR] go not found at $GO_BIN"
  exit 1
fi
cd "$SCRIPT_DIR"

OUT_BIN="${TMPDIR:-/tmp}/chipflow-tui-go-openchipflow"
GO_CACHE_DIR="${TMPDIR:-/tmp}/openchipflow-go-build-cache"
needs_build=0

if [ ! -x "$OUT_BIN" ]; then
  needs_build=1
else
  while IFS= read -r src; do
    if [ "$src" -nt "$OUT_BIN" ]; then
      needs_build=1
      break
    fi
  done < <(
    find cmd/chipflow-tui-go -type f
    printf '%s\n' go.mod go.sum
  )
fi

if [ "$needs_build" -eq 1 ]; then
  mkdir -p "$GO_CACHE_DIR"
  GOCACHE="$GO_CACHE_DIR" "$GO_BIN" build -o "$OUT_BIN" ./cmd/chipflow-tui-go
fi

exec "$OUT_BIN" --root "$SCRIPT_DIR" "$@"
