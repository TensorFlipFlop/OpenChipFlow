{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "permit_payload.schema.json",
  "title": "TB-3 Permit Payload",
  "type": "object",
  "required": [
    "version",
    "permit_id",
    "case_id",
    "issued_at",
    "issuer_role",
    "referee_model",
    "base_commit",
    "allow_tb3_change",
    "tb3_bindings",
    "forbidden",
    "required_regression"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "permit_id": { "type": "string", "minLength": 8 },
    "case_id": { "type": "string", "pattern": "^[A-Z]+_[0-9]{3,}$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "issuer_role": { "type": "string", "enum": ["Referee"] },
    "referee_model": { "type": "string", "minLength": 2 },
    "base_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "allow_tb3_change": { "type": "boolean", "const": true },
    "tb3_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "git_blob_sha1"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "git_blob_sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        },
        "additionalProperties": false
      }
    },
    "rationale": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["files", "rule"],
        "properties": {
          "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "rule": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "forbidden": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_new_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_regression": {
      "type": "array",
      "items": { "type": "string" }
    },
    "taboo_list": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
