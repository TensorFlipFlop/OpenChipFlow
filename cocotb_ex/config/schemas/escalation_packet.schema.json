{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "escalation_packet.schema.json",
  "title": "Cleanroom Escalation Packet",
  "type": "object",
  "required": [
    "version",
    "created_at",
    "case_id",
    "job_id",
    "spec",
    "repo_state",
    "code_snapshot",
    "error_summary",
    "repro",
    "taboo_list"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "case_id": { "type": "string" },
    "job_id": { "type": "string" },
    "spec": {
      "type": "object",
      "required": ["spec_ir_path", "spec_ir_sha256", "req_ids"],
      "properties": {
        "spec_ir_path": { "type": "string" },
        "spec_ir_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "req_ids": { "type": "array", "items": { "type": "string" } },
        "excerpt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "repo_state": {
      "type": "object",
      "required": ["head_commit", "branch"],
      "properties": {
        "head_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "branch": { "type": "string" },
        "dirty": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "code_snapshot": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "kind", "git_blob_sha1", "sha256", "excerpt"],
            "properties": {
              "path": { "type": "string" },
              "kind": { "type": "string", "enum": ["DUT", "TB1", "TB2", "TB3", "CASE", "CONFIG"] },
              "git_blob_sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "excerpt": { "type": "string" },
              "full_content_b64": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "staged_diff_unified_b64": { "type": "string" }
      },
      "additionalProperties": false
    },
    "error_summary": {
      "type": "object",
      "required": ["error_class", "tool", "message", "log_excerpt"],
      "properties": {
        "error_class": { "type": "string", "enum": ["SYNTAX", "LINT", "LOGIC", "INFRA", "FLAKY", "UNKNOWN"] },
        "tool": { "type": "string", "enum": ["verible", "verilator", "cocotb", "other"] },
        "message": { "type": "string" },
        "log_excerpt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "repro": {
      "type": "object",
      "required": ["cmd", "case_params"],
      "properties": {
        "cmd": { "type": "string" },
        "case_params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "taboo_list": {
      "type": "array",
      "description": "Failed directions/strategies to avoid repeating.",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
